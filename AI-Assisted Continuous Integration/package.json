{
  "name": "ai-test-maintenance",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "test": "set NODE_TLS_REJECT_UNAUTHORIZED=0 && playwright test",
    "test:headed": "playwright test --headed",
    "test:debug": "playwright test --debug",
    "test:report": "playwright show-report",
    "lint": "tsc --noEmit"
  },
  "devDependencies": {
    "@playwright/test": "latest",
    "@types/node": "^25.4.0",
    "dotenv": "^16.4.5",
    "typescript": "^5.4.5"
  }
}
